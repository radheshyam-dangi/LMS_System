{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "types": ["node", "jest"],

    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
   "strictPropertyInitialization": false, 
    "strict": true,
    "target": "es2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true
  },

  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}